class DeepAbstraction: def signature(self, examples: List[Tuple[Grid, Grid]]) -> str: parts = [] for inp, out in examples: parts.extend([ str(len(inp)), str(len(inp[0])), str(sum(cell for row in inp for cell in row)), str(len(out)), str(len(out[0])), str(sum(cell for row in out for cell in row)), ]) return "|".join(parts)

def concept(self, examples: List[Tuple[Grid, Grid]]) -> str:
first_in, first_out = examples[0]
if len(first_in) != len(first_out):
return "SIZE_CHANGE"
if first_in != first_out:
return "CONTENT_CHANGE"
return "IDENTITY"

