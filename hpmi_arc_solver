class Executor: def apply(self, rule: Rule, grid: Grid) -> Grid: if not rule: return copy.deepcopy(grid)

op = rule[0]

if op == "MOVE":
return self._move(grid, rule[1], rule[2])
if op == "RECOLOR":
return self._recolor(grid, rule[1], rule[2])
if op == "ROTATE":
return self._rotate(grid, rule[1])
if op == "FLIP":
return self._flip(grid, rule[1])
if op == "SCALE":
return self._scale(grid, rule[1])
if op == "IF_SIZE_GT":
threshold, subprogram = rule[1], rule[2]
size = sum(cell != 0 for row in grid for cell in row)
return self.run(subprogram, grid) if size > threshold else grid
if op == "LOOP":
times, subprogram = rule[1], rule[2]
out = copy.deepcopy(grid)
for _ in range(times):
out = self.run(subprogram, out)
return out
return copy.deepcopy(grid)

def run(self, program: Program, grid: Grid) -> Grid:
out = copy.deepcopy(grid)
for rule in program:
out = self.apply(rule, out)
return out

def _move(self, grid: Grid, dr: int, dc: int) -> Grid:
h, w = len(grid), len(grid[0])
out = [[0] * w for _ in range(h)]
for r in range(h):
for c in range(w):
nr, nc = r + dr, c + dc
if 0 <= nr < h and 0 <= nc < w:
out[nr][nc] = grid[r][c]
return out

def _recolor(self, grid: Grid, old: int, new: int) -> Grid:
return [[new if x == old else x for x in row] for row in grid]

def _rotate(self, grid: Grid, deg: int) -> Grid:
if deg == 90:
return [list(row) for row in zip(*grid[::-1])]
if deg == 180:
return [row[::-1] for row in grid[::-1]]
if deg == 270:
return [list(row) for row in zip(*grid)][::-1]
return copy.deepcopy(grid)

def _flip(self, grid: Grid, axis: str) -> Grid:
if axis == "H":
return [row[::-1] for row in grid]
if axis == "V":
return grid[::-1]
return copy.deepcopy(grid)

def _scale(self, grid: Grid, factor: int) -> Grid:
if factor <= 1:
return copy.deepcopy(grid)
h, w = len(grid), len(grid[0])
out = [[0] * (w * factor) for _ in range(h * factor)]
for r in range(h):
for c in range(w):
for dr in range(factor):
for dc in range(factor):
out[r * factor + dr][c * factor + dc] = grid[r][c]
return out

