class RuleInference: def infer(self, examples: List[Tuple[Grid, Grid]], obj_engine: ObjectEngine) -> List[Tuple[Rule, int]]: candidates: List[Rule] = []

for inp, out in examples:
in_objs = obj_engine.objects(inp)
out_objs = obj_engine.objects(out)

if in_objs and out_objs:
c1 = obj_engine.center(in_objs[0])
c2 = obj_engine.center(out_objs[0])
dr = round(c2[0] - c1[0])
dc = round(c2[1] - c1[1])
if dr or dc:
candidates.append(("MOVE", dr, dc))

old = in_objs[0][0][2]
new = out_objs[0][0][2]
if old != new:
candidates.append(("RECOLOR", old, new))

if self._rot(inp, out, 90):
candidates.append(("ROTATE", 90))
if self._rot(inp, out, 180):
candidates.append(("ROTATE", 180))
if self._rot(inp, out, 270):
candidates.append(("ROTATE", 270))

if self._flip(inp, out, "H"):
candidates.append(("FLIP", "H"))
if self._flip(inp, out, "V"):
candidates.append(("FLIP", "V"))

if len(out) == len(inp) * 2 and len(out[0]) == len(inp[0]) * 2:
candidates.append(("SCALE", 2))

if not candidates:
return [("IDENTITY",), 1]

return Counter(candidates).most_common(6)

@staticmethod
def _rot(a: Grid, b: Grid, deg: int) -> bool:
if deg == 90:
return [list(row) for row in zip(*a[::-1])] == b
if deg == 180:
return [row[::-1] for row in a[::-1]] == b
if deg == 270:
return [list(row) for row in zip(*a)][::-1] == b
return False

@staticmethod
def _flip(a: Grid, b: Grid, axis: str) -> bool:
if axis == "H":
return [row[::-1] for row in a] == b
if axis == "V":
return a[::-1] == b
return False

