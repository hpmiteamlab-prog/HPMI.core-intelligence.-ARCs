class SymbolicSynthesizer: def generate(self, rules: List[Tuple[Rule, int]], use_conditionals: bool) -> List[Program]: base_rules = [r for r, _ in rules] programs: List[Program] = []

for r in base_rules:
programs.append([r])

for r1 in base_rules:
for r2 in base_rules:
programs.append([r1, r2])
if use_conditionals:
programs.append([("LOOP", 2, [r1])])
programs.append([("IF_SIZE_GT", 3, [r2])])

return programs

