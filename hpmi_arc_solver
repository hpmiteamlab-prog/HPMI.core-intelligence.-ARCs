class SceneGraph: def init(self, objects: List[SceneObject]): self.objects = objects self.edges: List[Tuple[int, int, Tuple[str, ...]]] = [] self._build()

def _build(self) -> None:
for a in self.objects:
for b in self.objects:
if a.id == b.id:
continue
rel = []
if a.center[1] < b.center[1]:
rel.append("LEFT_OF")
if a.center[1] > b.center[1]:
rel.append("RIGHT_OF")
if a.center[0] < b.center[0]:
rel.append("ABOVE")
if a.center[0] > b.center[0]:
rel.append("BELOW")
if a.color == b.color:
rel.append("SAME_COLOR")
if a.bbox == b.bbox:
rel.append("SAME_SHAPE")
self.edges.append((a.id, b.id, tuple(rel)))

def relation_summary(self) -> Dict[str, int]:
counts = Counter()
for _, _, rel in self.edges:
for r in rel:
counts[r] += 1
return dict(counts)

