class AnalogicalEngine: def init(self): self.memory = []

def store(self, signature: str, program: Program) -> None:
self.memory.append((signature, copy.deepcopy(program)))

def find(self, signature: str) -> Optional[Program]:
best_prog = None
best_score = 0.0
for sig, prog in self.memory:
score = self._sim(signature, sig)
if score > best_score:
best_score = score
best_prog = copy.deepcopy(prog)
return best_prog if best_score > 0.65 else None

@staticmethod
def _sim(a: str, b: str) -> float:
pa = a.split("|")
pb = b.split("|")
if not pa or not pb:
return 0.0
return sum(1 for x, y in zip(pa, pb) if x == y) / max(len(pa), len(pb))

