class SmartSearch: def init(self, beam_width: int = 24, max_depth: int = 5, pruning: bool = True): self.beam_width = beam_width self.max_depth = max_depth self.pruning = pruning

def score(self, program: Program, examples: List[Tuple[Grid, Grid]], executor: Executor) -> float:
score = 0.0
for inp, out in examples:
try:
res = executor.run(program, inp)
if res == out:
score += 1.0
else:
if len(res) == len(out) and len(res[0]) == len(out[0]):
match = sum(
res[r][c] == out[r][c]
for r in range(len(out))
for c in range(len(out[0]))
)
score += match / (len(out) * len(out[0])) * 0.5
except Exception:
pass
return score

def heuristic(self, program: Program, examples: List[Tuple[Grid, Grid]], executor: Executor) -> float:
return self.score(program, examples, executor)

def search(self, candidate_programs: List[Program], examples: List[Tuple[Grid, Grid]], executor: Executor) -> Program:
if not candidate_programs:
return [("IDENTITY",)]

heap: List[Tuple[float, Program]] = []
for prog in candidate_programs:
h = self.heuristic(prog, examples, executor)
heapq.heappush(heap, (-h, prog))

seen = set()
best_prog = candidate_programs[0]
best_score = -1.0

while heap and len(seen) < 1200:
neg_h, prog = heapq.heappop(heap)
key = str(prog)
if key in seen:
continue
seen.add(key)

s = self.score(prog, examples, executor)
if s > best_score:
best_score = s
best_prog = prog

if s >= len(examples):
return prog

if len(prog) < self.max_depth:
for extra in candidate_programs[:self.beam_width]:
new_prog = prog + extra
if self.pruning and self.heuristic(new_prog, examples, executor) < 0.2:
continue
heapq.heappush(heap, (-self.heuristic(new_prog, examples, executor), new_prog))

return best_prog

