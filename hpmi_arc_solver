class Memory: def init(self): self.task_signatures: List[str] = [] self.programs: List[Program] = [] self.scores: List[float] = [] self.rule_stats: Dict[Rule, Dict[str, int]] = defaultdict(lambda: {"success": 0, "fail": 0})

@staticmethod
def _similarity(a: str, b: str) -> float:
pa = a.split("|")
pb = b.split("|")
if not pa or not pb:
return 0.0
return sum(1 for x, y in zip(pa, pb) if x == y) / max(len(pa), len(pb))

def store(self, signature: str, program: Program, score: float) -> None:
self.task_signatures.append(signature)
self.programs.append(copy.deepcopy(program))
self.scores.append(score)
for rule in program:
bucket = self.rule_stats[rule]
if score > 0:
bucket["success"] += 1
else:
bucket["fail"] += 1

def confidence(self, rule: Rule) -> float:
s = self.rule_stats[rule]["success"]
f = self.rule_stats[rule]["fail"] + 1
return s / f

def recall(self, signature: str, threshold: float = 0.7, limit: int = 5) -> List[Program]:
ranked: List[Tuple[float, Program]] = []
for sig, prog in zip(self.task_signatures, self.programs):
sim = self._similarity(signature, sig)
if sim >= threshold:
ranked.append((sim, copy.deepcopy(prog)))
ranked.sort(reverse=True, key=lambda x: x[0])
return [p for _, p in ranked[:limit]]

