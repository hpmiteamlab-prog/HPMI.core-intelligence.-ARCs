class RecursiveSynthesizer: def synthesize(self, programs: List[Program]) -> List[Program]: out: List[Program] = [] for prog in programs: if len(prog) >= 2: out.append([("LOOP", 2, prog[:1])]) out.append([("LOOP", 2, prog[:2])]) return out

