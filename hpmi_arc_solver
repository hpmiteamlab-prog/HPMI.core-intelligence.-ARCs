class OperatorInventor: def invent(self, examples: List[Tuple[Grid, Grid]], obj_engine: ObjectEngine) -> List[Rule]: invented: List[Rule] = []

for inp, out in examples:
in_objs = obj_engine.objects(inp)
out_objs = obj_engine.objects(out)

if len(in_objs) == len(out_objs) and in_objs:
invented.append(("ALIGN_OBJECTS",))

if len(out_objs) > len(in_objs):
invented.append(("OBJECT_SPLIT",))

if len(out_objs) < len(in_objs):
invented.append(("OBJECT_MERGE",))

return list(dict.fromkeys(invented))

