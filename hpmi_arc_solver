class ObjectEngine: def objects(self, grid: Grid) -> List[List[Tuple[int, int, int]]]: visited = set() objects: List[List[Tuple[int, int, int]]] = []

def bfs(sr: int, sc: int, color: int) -> List[Tuple[int, int, int]]:
q = deque([(sr, sc)])
cells: List[Tuple[int, int, int]] = []
while q:
r, c = q.popleft()
if (r, c) in visited:
continue
if r < 0 or c < 0 or r >= len(grid) or c >= len(grid[0]):
continue
if grid[r][c] != color or color == 0:
continue
visited.add((r, c))
cells.append((r, c, color))
for dr, dc in ((1, 0), (-1, 0), (0, 1), (0, -1)):
q.append((r + dr, c + dc))
return cells

for r in range(len(grid)):
for c in range(len(grid[0])):
if (r, c) not in visited and grid[r][c] != 0:
obj = bfs(r, c, grid[r][c])
if obj:
objects.append(obj)
return objects

@staticmethod
def center(obj: List[Tuple[int, int, int]]) -> Tuple[float, float]:
return (
sum(r for r, _, _ in obj) / len(obj),
sum(c for _, c, _ in obj) / len(obj),
)

@staticmethod
def bbox(obj: List[Tuple[int, int, int]]) -> Tuple[int, int, int, int]:
rows = [r for r, _, _ in obj]
cols = [c for _, c, _ in obj]
return min(rows), min(cols), max(rows), max(cols)

def shape_hash(self, obj: List[Tuple[int, int, int]]) -> Tuple[Tuple[int, int], ...]:
r0, c0, _, _ = self.bbox(obj)
return tuple(sorted((r - r0, c - c0) for r, c, _ in obj))

def scene_objects(self, grid: Grid) -> List[SceneObject]:
objs = self.objects(grid)
out: List[SceneObject] = []
for i, obj in enumerate(objs):
out.append(
SceneObject(
id=i,
pixels=obj,
color=obj[0][2],
size=len(obj),
center=self.center(obj),
bbox=self.bbox(obj),
)
)
return out

