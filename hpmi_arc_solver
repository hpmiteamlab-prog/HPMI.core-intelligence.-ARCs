class SelfReflection: def analyze(self, program: Program, examples: List[Tuple[Grid, Grid]], executor: Executor) -> str: shape_mismatch = False content_mismatch = False for inp, out in examples: try: res = executor.run(program, inp) if res != out: if len(res) != len(out) or len(res[0]) != len(out[0]): shape_mismatch = True else: content_mismatch = True except Exception: content_mismatch = True if not shape_mismatch and not content_mismatch: return "SUCCESS" if shape_mismatch: return "SHAPE_ERROR" if content_mismatch: return "CONTENT_ERROR" return "UNKNOWN"

